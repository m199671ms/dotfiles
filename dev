#!/bin/bash

# =====================================
# 🚀 Developer CLI Toolkit v6
# =====================================

COMMAND=$1
ARG1=$2
ARG2=$3

# --- Version & Update ---
SCRIPT_VERSION="1.2.0"
GITHUB_RAW_URL="https://raw.githubusercontent.com/m199671ms/dotfiles/main/dev"

# --- Colors ---
RED="\033[0;31m"
GREEN="\033[0;32m"
YELLOW="\033[1;33m"
CYAN="\033[0;36m"
BLUE="\033[0;34m"
MAGENTA="\033[0;35m"
BOLD="\033[1m"
NC="\033[0m"

# ──────────────────────────────────────
# OS DETECTION
# ──────────────────────────────────────

OS_TYPE=""
if [[ "$OSTYPE" == "darwin"* ]]; then
    OS_TYPE="macos"
elif [[ "$OSTYPE" == "linux-gnu"* ]]; then
    OS_TYPE="linux"
elif [[ "$OSTYPE" == "msys"* || "$OSTYPE" == "cygwin"* || "$OSTYPE" == "win32" ]]; then
    OS_TYPE="windows"
else
    if grep -qi "microsoft" /proc/version 2>/dev/null; then
        OS_TYPE="windows"
    else
        OS_TYPE="linux"
    fi
fi

# --- Paths based on OS ---
if [[ "$OS_TYPE" == "windows" ]]; then
    HOME_DIR="${USERPROFILE:-$HOME}"
    TMP_DIR="${TEMP:-/tmp}"
else
    HOME_DIR="$HOME"
    TMP_DIR="/tmp"
fi

CONFIG_FILE="$HOME_DIR/.devtoolkit_config"
PROJECTS_FILE="$HOME_DIR/.devtoolkit_projects"
LOG_FILE="$HOME_DIR/.devtoolkit.log"

# --- Script Path ---
if [[ "$OS_TYPE" == "windows" ]]; then
    SCRIPT_PATH="$(cd "$(dirname "$0")" && pwd)/$(basename "$0")"
else
    SCRIPT_PATH="$(realpath "$0")"
fi

# ──────────────────────────────────────
# UTILS
# ──────────────────────────────────────

function log_info()    { echo -e "${CYAN}ℹ️  $1${NC}"; }
function log_success() { echo -e "${GREEN}✅ $1${NC}"; }
function log_warn()    { echo -e "${YELLOW}⚠️  $1${NC}"; }
function log_error()   { echo -e "${RED}❌ $1${NC}"; }
function log_step()    { echo -e "${BLUE}▶  $1${NC}"; }
function divider()     { echo -e "${CYAN}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"; }

function log_to_file() {
    echo "[$(date '+%Y-%m-%d %H:%M:%S')] [$OS_TYPE] $1" >> "$LOG_FILE"
}

function require_command() {
    command -v "$1" &>/dev/null || {
        log_error "'$1' is not installed. Please install it first."
        exit 1
    }
}

function require_git_repo() {
    [ -d ".git" ] || {
        log_error "Not a git repository. Run 'dev create-repo' or 'git init' first."
        exit 1
    }
}

function confirm() {
    read -p "$1 (y/n): " _CONFIRM
    [[ "$_CONFIRM" == "y" ]]
}

function open_editor() {
    local DIR=${1:-.}
    load_config
    case "$OS_TYPE" in
        windows)
            if command -v "$EDITOR_PREF" &>/dev/null; then
                "$EDITOR_PREF" "$DIR" &
            elif command -v code &>/dev/null; then
                code "$DIR" &
            fi
            ;;
        *)
            command -v "$EDITOR_PREF" &>/dev/null && "$EDITOR_PREF" "$DIR" &
            ;;
    esac
}

function open_browser() {
    local URL=$1
    case "$OS_TYPE" in
        macos)   open "$URL" ;;
        linux)   xdg-open "$URL" 2>/dev/null ;;
        windows) cmd.exe /c start "$URL" 2>/dev/null ;;
    esac
}

# ──────────────────────────────────────
# NOTIFICATIONS
# ──────────────────────────────────────

function notify() {
    local TITLE=$1
    local MESSAGE=$2
    local SUCCESS=$3

    case "$OS_TYPE" in
        macos)
            local SOUND="Glass"
            [[ "$SUCCESS" == "false" ]] && SOUND="Basso"
            osascript -e "display notification \"$MESSAGE\" with title \"$TITLE\" sound name \"$SOUND\"" 2>/dev/null
            ;;
        windows)
            powershell.exe -Command "
                Add-Type -AssemblyName System.Windows.Forms
                \$notify = New-Object System.Windows.Forms.NotifyIcon
                \$notify.Icon = [System.Drawing.SystemIcons]::Information
                \$notify.Visible = \$true
                \$notify.ShowBalloonTip(5000, '$TITLE', '$MESSAGE', [System.Windows.Forms.ToolTipIcon]::Info)
            " 2>/dev/null
            ;;
        linux)
            command -v notify-send &>/dev/null && \
            notify-send "$TITLE" "$MESSAGE" 2>/dev/null
            ;;
    esac

    if [[ "$SUCCESS" == "false" ]]; then
        log_error "$TITLE — $MESSAGE"
    else
        log_success "$TITLE — $MESSAGE"
    fi
}

function run_with_notify() {
    local TITLE=$1
    local CMD=$2

    local START=$(date +%s)
    eval "$CMD"
    local EXIT_CODE=$?
    local END=$(date +%s)
    local DURATION=$((END - START))

    local TIME_STR=""
    if   (( DURATION >= 3600 )); then
        TIME_STR="$((DURATION/3600))h $((DURATION%3600/60))m"
    elif (( DURATION >= 60 )); then
        TIME_STR="$((DURATION/60))m $((DURATION%60))s"
    else
        TIME_STR="${DURATION}s"
    fi

    if [ $EXIT_CODE -eq 0 ]; then
        notify "✅ $TITLE" "اكتمل في $TIME_STR" "true"
        log_to_file "$TITLE completed in $TIME_STR"
    else
        notify "❌ $TITLE" "فشل بعد $TIME_STR" "false"
        log_to_file "$TITLE FAILED after $TIME_STR"
    fi

    return $EXIT_CODE
}

# ──────────────────────────────────────
# SELF UPDATE
# ──────────────────────────────────────

function self_update() {
    require_command gh

    divider
    echo -e "${BOLD}🔄 Checking for updates...${NC}"
    divider

    local TMP_FILE="$TMP_DIR/_dev_update_tmp"

    if ! gh api repos/m199671ms/dotfiles/contents/dev \
        --jq '.content' | base64 --decode > "$TMP_FILE" 2>/dev/null; then
        log_error "Could not download update. Check 'gh auth status'."
        rm -f "$TMP_FILE"
        exit 1
    fi

    if ! head -1 "$TMP_FILE" | grep -q "bash"; then
        log_error "Downloaded file doesn't look like a valid script."
        rm -f "$TMP_FILE"
        exit 1
    fi

    local REMOTE_VERSION
    REMOTE_VERSION=$(grep 'SCRIPT_VERSION=' "$TMP_FILE" | head -1 | cut -d'"' -f2)

    if [[ -z "$REMOTE_VERSION" ]]; then
        log_warn "Could not determine remote version."
        rm -f "$TMP_FILE"
        exit 1
    fi

    echo -e "  Platform        : ${CYAN}$OS_TYPE${NC}"
    echo -e "  Current version : ${YELLOW}$SCRIPT_VERSION${NC}"
    echo -e "  Latest version  : ${GREEN}$REMOTE_VERSION${NC}"
    echo ""

    if [[ "$SCRIPT_VERSION" == "$REMOTE_VERSION" ]]; then
        log_success "Already up to date!"
        rm -f "$TMP_FILE"
        return 0
    fi

    read -p "Update to v$REMOTE_VERSION? (y/n): " CONFIRM
    if [[ "$CONFIRM" != "y" ]]; then
        log_warn "Update cancelled."
        rm -f "$TMP_FILE"
        return 0
    fi

    local BACKUP_PATH="${SCRIPT_PATH}.backup_v${SCRIPT_VERSION}"
    cp "$SCRIPT_PATH" "$BACKUP_PATH"
    log_info "Backup saved: $BACKUP_PATH"

    mv "$TMP_FILE" "$SCRIPT_PATH"
    chmod +x "$SCRIPT_PATH"

    log_success "Updated to v$REMOTE_VERSION successfully!"
    log_to_file "Script updated: $SCRIPT_VERSION → $REMOTE_VERSION"
    echo -e "${CYAN}ℹ️  Changes will apply on next run.${NC}"
}

function self_rollback() {
    divider
    echo -e "${BOLD}⏪ Rollback${NC}"
    divider

    local BACKUPS=($(ls "${SCRIPT_PATH}.backup_v"* 2>/dev/null | sort -r))

    if [[ ${#BACKUPS[@]} -eq 0 ]]; then
        log_error "No backups found."
        return 1
    fi

    echo -e "${BOLD}Available backups:${NC}"
    for i in "${!BACKUPS[@]}"; do
        local VER=$(echo "${BACKUPS[$i]}" | grep -o 'v[0-9.]*$')
        echo "  $((i+1))) $VER — ${BACKUPS[$i]}"
    done
    echo ""

    read -p "Choose backup [1-${#BACKUPS[@]}]: " CHOICE
    local INDEX=$((CHOICE - 1))

    if [[ -z "${BACKUPS[$INDEX]}" ]]; then
        log_error "Invalid choice."
        return 1
    fi

    cp "${BACKUPS[$INDEX]}" "$SCRIPT_PATH"
    chmod +x "$SCRIPT_PATH"
    log_success "Rolled back to $(echo "${BACKUPS[$INDEX]}" | grep -o 'v[0-9.]*$')!"
}

# ──────────────────────────────────────
# CONFIG
# ──────────────────────────────────────

function load_config() {
    if [ ! -f "$CONFIG_FILE" ]; then
        divider
        echo -e "${BOLD}⚙️  First time setup${NC}"
        echo -e "   Platform: ${CYAN}$OS_TYPE${NC}"
        divider
        read -p "Personal GitHub email : " PERSONAL_EMAIL
        read -p "Company GitHub email  : " COMPANY_EMAIL
        read -p "Your full name        : " GIT_NAME
        read -p "Default editor (code/vim/nano): " EDITOR_PREF
        EDITOR_PREF="${EDITOR_PREF:-code}"
        {
            echo "PERSONAL_EMAIL=$PERSONAL_EMAIL"
            echo "COMPANY_EMAIL=$COMPANY_EMAIL"
            echo "GIT_NAME=$GIT_NAME"
            echo "EDITOR_PREF=$EDITOR_PREF"
        } > "$CONFIG_FILE"
        git config --global user.name "$GIT_NAME"
        log_success "Config saved at $CONFIG_FILE"
    fi
    source "$CONFIG_FILE"
}

function edit_config() {
    load_config
    echo -e "${BOLD}Current config:${NC}"
    cat "$CONFIG_FILE"
    echo ""
    if confirm "Edit config?"; then
        read -p "Personal email [$PERSONAL_EMAIL]: " _PE
        read -p "Company email  [$COMPANY_EMAIL]: " _CE
        read -p "Full name      [$GIT_NAME]: " _GN
        read -p "Editor         [$EDITOR_PREF]: " _ED
        {
            echo "PERSONAL_EMAIL=${_PE:-$PERSONAL_EMAIL}"
            echo "COMPANY_EMAIL=${_CE:-$COMPANY_EMAIL}"
            echo "GIT_NAME=${_GN:-$GIT_NAME}"
            echo "EDITOR_PREF=${_ED:-$EDITOR_PREF}"
        } > "$CONFIG_FILE"
        log_success "Config updated."
    fi
}

# ──────────────────────────────────────
# SSH
# ──────────────────────────────────────

function check_ssh() {
    load_config
    log_info "Checking SSH keys..."
    SSH_PATH="$HOME_DIR/.ssh"
    mkdir -p "$SSH_PATH"

    # التحقق من OpenSSH على Windows
    if [[ "$OS_TYPE" == "windows" ]]; then
        if ! command -v ssh-keygen &>/dev/null; then
            log_error "OpenSSH not found."
            log_info "Install: Settings → Apps → Optional Features → OpenSSH Client"
            exit 1
        fi
        powershell.exe -Command "
            Set-Service ssh-agent -StartupType Automatic
            Start-Service ssh-agent
        " 2>/dev/null
    fi

    read -p "Account type (personal/company): " ACCOUNT
    case "$ACCOUNT" in
        personal) KEY_NAME="github_personal"; EMAIL_VAR="$PERSONAL_EMAIL" ;;
        company)  KEY_NAME="github_company";  EMAIL_VAR="$COMPANY_EMAIL"  ;;
        *) log_error "Invalid account. Use: personal or company"; exit 1 ;;
    esac

    if [ ! -f "$SSH_PATH/$KEY_NAME" ]; then
        log_step "Generating SSH key for '$ACCOUNT'..."
        ssh-keygen -t ed25519 -C "$EMAIL_VAR" -f "$SSH_PATH/$KEY_NAME" -N ""
        echo -e "${GREEN}📋 Add this key to GitHub → Settings → SSH Keys:${NC}"
        echo -e "${CYAN}$(cat "$SSH_PATH/$KEY_NAME.pub")${NC}"
        read -p "Press Enter after adding to GitHub..."
    fi

    eval "$(ssh-agent -s)" > /dev/null
    ssh-add "$SSH_PATH/$KEY_NAME" > /dev/null
    log_success "SSH key loaded: $KEY_NAME"
    log_to_file "SSH loaded: $KEY_NAME"
}

# ──────────────────────────────────────
# GIT HELPERS
# ──────────────────────────────────────

function quick_push() {
    require_git_repo
    local MSG=$ARG1
    [[ -z "$MSG" ]] && read -p "Commit message: " MSG
    [[ -z "$MSG" ]] && log_error "Commit message is required." && exit 1

    log_step "Staging all changes..."
    git add .
    git commit -m "$MSG" || { log_warn "Nothing to commit."; exit 0; }
    if git push; then
        log_success "Pushed: \"$MSG\""
        log_to_file "Pushed: $MSG"
    else
        log_error "Push failed. Check your remote/permissions."
        exit 1
    fi
}

function git_status() {
    require_git_repo
    divider
    echo -e "${BOLD}📋 Git Status${NC}"
    divider
    BRANCH=$(git branch --show-current)
    REMOTE=$(git remote get-url origin 2>/dev/null || echo "No remote")
    AHEAD=$(git rev-list --count @{u}..HEAD 2>/dev/null || echo "?")
    echo -e "  Branch : ${GREEN}$BRANCH${NC}"
    echo -e "  Remote : ${CYAN}$REMOTE${NC}"
    echo -e "  Ahead  : ${YELLOW}$AHEAD commits${NC}"
    echo ""
    git status -s
    echo ""
    echo -e "${BOLD}Last 7 commits:${NC}"
    git log --oneline -7 --decorate --color
    divider
}

function new_branch() {
    require_git_repo
    local BRANCH=$ARG1
    [[ -z "$BRANCH" ]] && read -p "Branch name: " BRANCH
    [[ -z "$BRANCH" ]] && log_error "Branch name is required." && exit 1

    git checkout -b "$BRANCH" \
        && log_success "Created and switched to: $BRANCH" \
        || log_error "Failed to create branch."
}

function switch_branch() {
    require_git_repo
    echo -e "${BOLD}Available branches:${NC}"
    git branch -a --color
    echo ""
    read -p "Branch to switch to: " BRANCH
    git checkout "$BRANCH" \
        && log_success "Switched to: $BRANCH" \
        || log_error "Failed to switch branch."
}

function merge_and_clean() {
    require_git_repo
    CURRENT=$(git branch --show-current)
    read -p "Merge '$CURRENT' into (default: main): " TARGET
    TARGET="${TARGET:-main}"

    git checkout "$TARGET" \
        && git merge "$CURRENT" \
        && git branch -d "$CURRENT" \
        && log_success "Merged '$CURRENT' → '$TARGET' and deleted branch." \
        || log_error "Merge failed."
}

function undo_commit() {
    require_git_repo
    git reset --soft HEAD~1 \
        && log_success "Last commit undone. Changes kept in staging." \
        || log_error "Failed to undo commit."
}

function sync_repo() {
    require_git_repo
    BRANCH=$(git branch --show-current)
    log_step "Syncing '$BRANCH' with remote..."
    git pull --rebase origin "$BRANCH" \
        && log_success "Synced successfully!" \
        || log_error "Sync failed. Resolve conflicts then run 'git rebase --continue'."
}

function clean_branches() {
    require_git_repo
    log_step "Deleting merged branches..."
    git branch --merged main | grep -v "^\*\|main\|master" | xargs git branch -d 2>/dev/null \
        && log_success "Merged branches cleaned." \
        || log_warn "No merged branches to clean."
}

function git_log() {
    require_git_repo
    git log --graph --oneline --decorate --all --color | head -30
}

# ──────────────────────────────────────
# PROJECT MANAGER
# ──────────────────────────────────────

function save_project() {
    local NAME=$ARG1
    [[ -z "$NAME" ]] && read -p "Project alias: " NAME
    [[ -z "$NAME" ]] && log_error "Alias is required." && exit 1

    touch "$PROJECTS_FILE"
    grep -v "^$NAME=" "$PROJECTS_FILE" > "$TMP_DIR/_proj_tmp" && mv "$TMP_DIR/_proj_tmp" "$PROJECTS_FILE"
    echo "$NAME=$(pwd)" >> "$PROJECTS_FILE"
    log_success "Project '$NAME' saved → $(pwd)"
}

function goto_project() {
    local NAME=$ARG1
    if [[ -z "$NAME" ]]; then
        list_projects
        read -p "Project name: " NAME
    fi
    local PROJ_PATH
    PROJ_PATH=$(grep "^$NAME=" "$PROJECTS_FILE" 2>/dev/null | cut -d= -f2)
    if [[ -n "$PROJ_PATH" && -d "$PROJ_PATH" ]]; then
        cd "$PROJ_PATH" || exit 1
        log_success "Switched to: $PROJ_PATH"
        open_editor .
    else
        log_error "Project '$NAME' not found or path missing."
    fi
}

function list_projects() {
    divider
    echo -e "${BOLD}📁 Saved Projects${NC}"
    divider
    if [ -f "$PROJECTS_FILE" ] && [ -s "$PROJECTS_FILE" ]; then
        while IFS='=' read -r name path; do
            if [ -d "$path" ]; then
                echo -e "  ${GREEN}● $name${NC} → $path"
            else
                echo -e "  ${RED}✗ $name${NC} → $path ${YELLOW}(missing)${NC}"
            fi
        done < "$PROJECTS_FILE"
    else
        log_warn "No projects saved. Use: dev save-project <n>"
    fi
    divider
}

function remove_project() {
    local NAME=$ARG1
    [[ -z "$NAME" ]] && read -p "Project alias to remove: " NAME
    grep -v "^$NAME=" "$PROJECTS_FILE" > "$TMP_DIR/_proj_tmp" && mv "$TMP_DIR/_proj_tmp" "$PROJECTS_FILE"
    log_success "Project '$NAME' removed."
}

# ──────────────────────────────────────
# FLUTTER
# ──────────────────────────────────────

function flutter_new() {
    require_command flutter
    local NAME=$ARG1
    [[ -z "$NAME" ]] && read -p "Project name: " NAME
    [[ -z "$NAME" ]] && log_error "Project name is required." && exit 1

    read -p "Organization (e.g. com.company): " ORG
    ORG="${ORG:-com.example}"

    log_step "Creating Flutter project: $NAME"
    flutter create --org "$ORG" "$NAME" \
        && log_success "Flutter project '$NAME' created!" \
        || { log_error "flutter create failed."; exit 1; }
}

function flutter_run_device() {
    require_command flutter

    # تشغيل مشروع محدد بالاسم أو المسار
    if [[ -n "$ARG1" ]]; then
        local TARGET_PATH=""
        if [[ -d "$ARG1" ]]; then
            TARGET_PATH="$ARG1"
        elif grep -q "^$ARG1=" "$PROJECTS_FILE" 2>/dev/null; then
            TARGET_PATH=$(grep "^$ARG1=" "$PROJECTS_FILE" | cut -d= -f2)
        else
            log_error "Project '$ARG1' not found."
            exit 1
        fi
        log_step "Switching to: $TARGET_PATH"
        cd "$TARGET_PATH" || exit 1
    fi

    if [ ! -f "pubspec.yaml" ]; then
        log_error "No Flutter project found in: $(pwd)"
        exit 1
    fi

    divider
    echo -e "${BOLD}⚡ Flutter Run${NC}"
    echo -e "   Platform: ${CYAN}$OS_TYPE${NC}"
    divider

    case "$OS_TYPE" in
        macos)
            echo "  1) Android"
            echo "  2) iOS"
            echo "  3) macOS (Desktop)"
            echo "  4) Web"
            echo "  5) اختيار جهاز محدد"
            ;;
        windows)
            echo "  1) Android"
            echo "  2) Windows (Desktop)"
            echo "  3) Web"
            echo "  4) اختيار جهاز محدد"
            ;;
        linux)
            echo "  1) Android"
            echo "  2) Linux (Desktop)"
            echo "  3) Web"
            echo "  4) اختيار جهاز محدد"
            ;;
    esac
    divider
    read -p "Choice: " CHOICE

    function _fix_cocoapods() {
        log_warn "CocoaPods dependency issue detected. Fixing automatically..."
        if [ ! -d "ios" ]; then
            log_error "No ios folder found."
            return 1
        fi
        cd ios
        log_step "Attempt 1: Updating conflicting pods..."
        if pod update sqlite3 > /dev/null 2>&1; then
            log_success "Pods updated successfully."
            cd ..
            return 0
        fi
        log_step "Attempt 2: Updating CocoaPods repos..."
        if pod repo update > /dev/null 2>&1 && pod install > /dev/null 2>&1; then
            log_success "CocoaPods repos updated."
            cd ..
            return 0
        fi
        log_step "Attempt 3: Full CocoaPods reinstall..."
        pod deintegrate > /dev/null 2>&1
        if pod install --repo-update > /dev/null 2>&1; then
            log_success "CocoaPods reinstalled successfully."
            cd ..
            return 0
        fi
        cd ..
        log_error "Could not fix CocoaPods. Try: cd ios && pod install --repo-update"
        return 1
    }

    function _run_with_error_handling() {
        local DEVICE_FLAG=$1
        local MAX_RETRIES=2
        local ATTEMPT=0

        while [ $ATTEMPT -le $MAX_RETRIES ]; do
            ATTEMPT=$((ATTEMPT + 1))
            log_step "Launching Flutter app (attempt $ATTEMPT)..."

            local TMP_LOG="$TMP_DIR/_flutter_run_log"
            flutter run $DEVICE_FLAG 2>&1 | tee "$TMP_LOG"
            EXIT_CODE=${PIPESTATUS[0]}
            OUTPUT=$(cat "$TMP_LOG")
            rm -f "$TMP_LOG"

            if [ $EXIT_CODE -eq 0 ]; then
                log_success "Session ended."
                return 0
            fi

            if echo "$OUTPUT" | grep -q "Flutter run key commands\|Syncing files to device\|To hot reload\|Running with"; then
                log_success "App was running successfully."
                return 0
            fi

            if echo "$OUTPUT" | grep -q "CocoaPods.*out-of-date\|pod install\|CocoaPods could not find compatible"; then
                log_warn "CocoaPods issue detected on attempt $ATTEMPT."
                [ $ATTEMPT -le $MAX_RETRIES ] && _fix_cocoapods && continue
            fi

            if echo "$OUTPUT" | grep -q "Gradle\|gradle"; then
                log_warn "Gradle issue detected. Cleaning and retrying..."
                flutter clean > /dev/null 2>&1
                flutter pub get > /dev/null 2>&1
                continue
            fi

            if echo "$OUTPUT" | grep -q "pub get\|pubspec"; then
                log_warn "Pub dependencies issue. Running flutter pub get..."
                flutter pub get && continue
            fi

            log_error "Launch failed. Exit code: $EXIT_CODE"
            return 1
        done

        log_error "Failed after $MAX_RETRIES attempts."
        return 1
    }

    case "$OS_TYPE" in
        macos)
            case $CHOICE in
                1)
                    DEVICES=$(flutter devices 2>/dev/null | grep -i "android")
                    [[ -z "$DEVICES" ]] && { log_error "No Android devices found."; exit 1; }
                    echo "$DEVICES"
                    read -p "Device ID (empty = first available): " DEVICE
                    _run_with_error_handling "-d ${DEVICE:-android}"
                    ;;
                2)
                    DEVICES=$(flutter devices 2>/dev/null | grep -i "ios\|iphone\|ipad")
                    [[ -z "$DEVICES" ]] && { log_error "No iOS devices found."; exit 1; }
                    echo "$DEVICES"
                    read -p "Device ID (empty = first available): " DEVICE
                    _run_with_error_handling "-d ${DEVICE:-ios}"
                    ;;
                3) _run_with_error_handling "-d macos" ;;
                4)
                    read -p "Browser (chrome/edge, default: chrome): " BROWSER
                    _run_with_error_handling "-d ${BROWSER:-chrome}"
                    ;;
                5)
                    flutter devices
                    read -p "Device ID: " DEVICE
                    [[ -z "$DEVICE" ]] && { log_error "Device ID required."; exit 1; }
                    _run_with_error_handling "-d $DEVICE"
                    ;;
                *) log_error "Invalid choice." && exit 1 ;;
            esac
            ;;
        windows)
            case $CHOICE in
                1)
                    DEVICES=$(flutter devices 2>/dev/null | grep -i "android")
                    [[ -z "$DEVICES" ]] && { log_error "No Android devices found."; exit 1; }
                    echo "$DEVICES"
                    read -p "Device ID (empty = first available): " DEVICE
                    _run_with_error_handling "-d ${DEVICE:-android}"
                    ;;
                2) _run_with_error_handling "-d windows" ;;
                3)
                    read -p "Browser (chrome/edge, default: chrome): " BROWSER
                    _run_with_error_handling "-d ${BROWSER:-chrome}"
                    ;;
                4)
                    flutter devices
                    read -p "Device ID: " DEVICE
                    [[ -z "$DEVICE" ]] && { log_error "Device ID required."; exit 1; }
                    _run_with_error_handling "-d $DEVICE"
                    ;;
                *) log_error "Invalid choice." && exit 1 ;;
            esac
            ;;
        linux)
            case $CHOICE in
                1)
                    DEVICES=$(flutter devices 2>/dev/null | grep -i "android")
                    [[ -z "$DEVICES" ]] && { log_error "No Android devices found."; exit 1; }
                    echo "$DEVICES"
                    read -p "Device ID (empty = first available): " DEVICE
                    _run_with_error_handling "-d ${DEVICE:-android}"
                    ;;
                2) _run_with_error_handling "-d linux" ;;
                3)
                    read -p "Browser (chrome/edge, default: chrome): " BROWSER
                    _run_with_error_handling "-d ${BROWSER:-chrome}"
                    ;;
                4)
                    flutter devices
                    read -p "Device ID: " DEVICE
                    [[ -z "$DEVICE" ]] && { log_error "Device ID required."; exit 1; }
                    _run_with_error_handling "-d $DEVICE"
                    ;;
                *) log_error "Invalid choice." && exit 1 ;;
            esac
            ;;
    esac
}

