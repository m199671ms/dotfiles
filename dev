function web_serve() {
    local PORT=$ARG1
    PORT="${PORT:-3000}"
    if command -v npx &>/dev/null; then
        log_step "Starting local server on http://localhost:$PORT"
        open_browser "http://localhost:$PORT"
        npx serve -l "$PORT" .
    elif command -v python3 &>/dev/null; then
        log_step "Starting Python server on http://localhost:$PORT"
        open_browser "http://localhost:$PORT"
        python3 -m http.server "$PORT"
    else
        log_error "No server available. Install Node.js or Python3."
    fi
}

