#!/bin/bash
# =====================================
# 🚀 Developer CLI Toolkit v6
# =====================================

SCRIPT_VERSION="1.5.0"
GITHUB_RAW_URL="https://raw.githubusercontent.com/m199671ms/dotfiles/main/dev"

COMMAND=$1
ARG1=$2
ARG2=$3

# ── OS Detection ──────────────────────
OS_TYPE=""
if [[ "$OSTYPE" == "darwin"* ]]; then
    OS_TYPE="macos"
elif [[ "$OSTYPE" == "linux-gnu"* ]]; then
    OS_TYPE="linux"
elif [[ "$OSTYPE" == "msys"* || "$OSTYPE" == "cygwin"* || "$OSTYPE" == "win32" ]]; then
    OS_TYPE="windows"
else
    if grep -qi "microsoft" /proc/version 2>/dev/null; then
        OS_TYPE="windows"
    else
        OS_TYPE="linux"
    fi
fi

# ── Paths ─────────────────────────────
if [[ "$OS_TYPE" == "windows" ]]; then
    HOME_DIR="${USERPROFILE:-$HOME}"
    TMP_DIR="${TEMP:-/tmp}"
else
    HOME_DIR="$HOME"
    TMP_DIR="/tmp"
fi

CONFIG_FILE="$HOME_DIR/.devtoolkit_config"
PROJECTS_FILE="$HOME_DIR/.devtoolkit_projects"
LOG_FILE="$HOME_DIR/.devtoolkit.log"

if [[ "$OS_TYPE" == "windows" ]]; then
    SCRIPT_PATH="$(cd "$(dirname "$0")" && pwd)/$(basename "$0")"
else
    SCRIPT_PATH="$(realpath "$0")"
fi

# ── Load Modules ──────────────────────
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
LIB_DIR="$SCRIPT_DIR/lib"

for module in utils config update git projects flutter docker frameworks repo doctor aliases help; do
    source "$LIB_DIR/${module}" || {
        echo "❌ Failed to load module: ${module}"
        exit 1
    }
done

# ── Dispatcher ────────────────────────
case "$COMMAND" in
    create-repo)     create_repo ;;
    push)            quick_push ;;
    sync)            sync_repo ;;
    status)          git_status ;;
    log)             git_log ;;
    new-branch)      new_branch ;;
    switch-branch)   switch_branch ;;
    merge-clean)     merge_and_clean ;;
    clean-branches)  clean_branches ;;
    undo)            undo_commit ;;
    save-project)    save_project ;;
    goto)            goto_project ;;
    projects)        list_projects ;;
    remove-project)  remove_project ;;
    flutter-new)     flutter_new ;;
    flutter-run)     flutter_run_device ;;
    flutter-build)   flutter_build ;;
    flutter-test)    flutter_test ;;
    flutter-upgrade) flutter_upgrade ;;
    clean)           flutter clean && log_success "Cleaned!" ;;
    docker-build)    docker_build "$ARG1" ;;
    docker-run)      docker_run "$ARG1" ;;
    docker-list)     docker_list ;;
    docker-stop)     docker_stop_all ;;
    docker-clean)    docker_clean ;;
    compose-up)      docker_compose_up ;;
    compose-down)    docker_compose_down ;;
    npm-install)     node_install ;;
    npm-run)         node_run ;;
    npm-build)       node_build ;;
    vue-new)         vue_new ;;
    dotnet-new)      dotnet_new ;;
    dotnet-run)      dotnet_run ;;
    dotnet-build)    dotnet_build ;;
    dotnet-test)     dotnet_test ;;
    web-serve)       web_serve ;;
    ssh-check)       check_ssh ;;
    doctor)          run_doctor ;;
    config)          edit_config ;;
    info)            show_info ;;
    logs)            show_logs ;;
    update)          self_update ;;
    rollback)        self_rollback ;;
    alias-add)       alias_add ;;
    alias-remove)    alias_remove ;;
    alias-list)      alias_list ;;
    help|--help|-h)  show_help ;;
    *)
        load_aliases
        VAR_NAME="alias_map_${COMMAND}"
        if [[ -n "${!VAR_NAME}" ]]; then
            run_alias "$COMMAND"
        else
            show_help
        fi
        ;;
esac
