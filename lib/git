#!/bin/bash
# ──────────────────────────────────────
# git.sh — Git Operations
# ──────────────────────────────────────

function quick_push() {
    require_git_repo

    # تحميل SSH key قبل أي عملية push
    eval "$(ssh-agent -s)" > /dev/null
    ssh-add "$HOME_DIR/.ssh/github_personal" > /dev/null 2>&1

    # ── Check for pending (unpushed) commits ──
    local PENDING_COUNT
    PENDING_COUNT=$(git rev-list --count @{u}..HEAD 2>/dev/null || echo 0)

    if (( PENDING_COUNT > 0 )); then
        echo ""
        divider
        echo -e "${YELLOW}$(t git_pending_title "$PENDING_COUNT")${NC}"
        echo ""
        git log --oneline --decorate --color @{u}..HEAD
        echo ""
        divider
        echo -e "  ${CYAN}$(t git_pending_opt1)${NC}"
        echo -e "  ${CYAN}$(t git_pending_opt2)${NC}"
        echo -e "  ${CYAN}$(t git_pending_opt3)${NC}"
        echo ""
        read -p "$(t git_pending_choose): " PENDING_CHOICE

        case "$PENDING_CHOICE" in
            1)
                log_step "$(t git_pending_pushing)"
                if git push; then
                    log_success "$(t git_pending_pushed "$PENDING_COUNT")"
                    log_to_file "Pushed $PENDING_COUNT pending commit(s)"
                else
                    local PUSH_EXIT=$?
                    _push_error_hints
                    exit $PUSH_EXIT
                fi
                return 0
                ;;
            2)
                local MSG=$ARG1
                [[ -z "$MSG" ]] && read -p "$(t git_pending_commit_msg): " MSG
                [[ -z "$MSG" ]] && log_error "$(t git_commit_required)" && exit 1

                log_step "$(t git_staging)"
                git add .
                git commit -m "$MSG" || { log_warn "$(t git_pending_no_changes)"; }

                log_step "$(t git_pending_pushing_all "$((PENDING_COUNT + 1))")"
                if git push; then
                    log_success "$(t git_pending_pushed_all)"
                    log_to_file "Pushed all commits: $MSG"
                else
                    local PUSH_EXIT=$?
                    _push_error_hints
                    exit $PUSH_EXIT
                fi
                return 0
                ;;
            3)
                log_warn "$(t git_pending_cancelled)"
                return 0
                ;;
            *)
                log_error "$(t git_pending_invalid)"
                exit 1
                ;;
        esac
    fi

    # ── Normal flow: no pending commits ──
    local MSG=$ARG1
    [[ -z "$MSG" ]] && read -p "$(t git_commit_msg): " MSG
    [[ -z "$MSG" ]] && log_error "$(t git_commit_required)" && exit 1

    log_step "$(t git_staging)"
    git add .
    git commit -m "$MSG" || { log_warn "$(t git_nothing_commit)"; exit 0; }

    if git push; then
        log_success "$(t git_pushed "$MSG")"
        log_to_file "Pushed: $MSG"
    else
        local PUSH_EXIT=$?
        _push_error_hints
        exit $PUSH_EXIT
    fi
}

# ── Helper: push error hints ──
function _push_error_hints() {
    log_error "$(t git_push_failed)"
    echo ""
    echo -e "${YELLOW}$(t git_push_tips)${NC}"
    echo -e "  • $(t git_push_tip1)"
    echo -e "  • $(t git_push_tip2)"
    echo -e "  • $(t git_push_tip3)"
    echo -e "  • $(t git_push_tip4)"
    echo ""
}

function git_status() {
    require_git_repo
    divider
    echo -e "${BOLD}$(t git_status_title)${NC}"
    divider
    local BRANCH REMOTE AHEAD
    BRANCH=$(git branch --show-current)
    REMOTE=$(git remote get-url origin 2>/dev/null || echo "No remote")
    AHEAD=$(git rev-list --count @{u}..HEAD 2>/dev/null || echo "?")
    echo -e "  $(t git_branch_label) : ${GREEN}$BRANCH${NC}"
    echo -e "  $(t git_remote_label) : ${CYAN}$REMOTE${NC}"
    echo -e "  $(t git_ahead_label)  : ${YELLOW}$AHEAD $(t git_ahead_commits)${NC}"
    echo ""
    git status -s
    echo ""
    echo -e "${BOLD}Last 7 commits:${NC}"
    git log --oneline -7 --decorate --color
    divider
}

function new_branch() {
    require_git_repo
    local BRANCH=$ARG1
    [[ -z "$BRANCH" ]] && read -p "$(t git_branch_name): " BRANCH
    [[ -z "$BRANCH" ]] && log_error "$(t git_branch_required)" && exit 1

    git checkout -b "$BRANCH" \
        && log_success "$(t git_branch_created "$BRANCH")" \
        || log_error "$(t git_branch_failed)"
}

function switch_branch() {
    require_git_repo
    echo -e "${BOLD}$(t git_branch_list)${NC}"
    git branch -a --color
    echo ""
    read -p "$(t git_branch_switch): " BRANCH
    git checkout "$BRANCH" \
        && log_success "$(t git_branch_switched "$BRANCH")" \
        || log_error "$(t git_branch_failed)"
}

function merge_and_clean() {
    require_git_repo
    local CURRENT
    CURRENT=$(git branch --show-current)
    read -p "$(t git_merge_into "$CURRENT"): " TARGET
    TARGET="${TARGET:-main}"

    git checkout "$TARGET" \
        && git merge "$CURRENT" \
        && git branch -d "$CURRENT" \
        && log_success "$(t git_merged "$CURRENT" "$TARGET")" \
        || log_error "$(t git_merge_failed)"
}

function undo_commit() {
    require_git_repo
    git reset --soft HEAD~1 \
        && log_success "$(t git_undo_done)" \
        || log_error "$(t git_undo_failed)"
}

function sync_repo() {
    require_git_repo
    local BRANCH
    BRANCH=$(git branch --show-current)
    log_step "$(t git_syncing "$BRANCH")"
    git pull --rebase origin "$BRANCH" \
        && log_success "$(t git_synced)" \
        || {
            log_error "$(t git_sync_failed)"
            echo -e "${YELLOW}$(t git_sync_tips)${NC}"
            echo -e "  $(t git_sync_tip1)"
            echo -e "  $(t git_sync_tip2)"
            echo -e "  $(t git_sync_tip3)"
            echo -e "  $(t git_sync_abort)"
        }
}

function clean_branches() {
    require_git_repo
    log_step "Deleting merged branches..."
    git branch --merged main | grep -v "^\*\|main\|master" \
        | xargs git branch -d 2>/dev/null \
        && log_success "Merged branches cleaned." \
        || log_warn "No merged branches to clean."
}

function git_log() {
    require_git_repo
    git log --graph --oneline --decorate --all --color | head -30
}
