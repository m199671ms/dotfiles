#!/bin/bash
# ──────────────────────────────────────
# update.sh — Self Update & Rollback
# ──────────────────────────────────────

function self_update() {
    require_command gh

    eval "$(ssh-agent -s)" > /dev/null
    ssh-add "$HOME_DIR/.ssh/github_personal" > /dev/null 2>&1

    divider
    echo -e "${BOLD}$(t update_checking)${NC}"
    divider

    local SCRIPT_DIR
    SCRIPT_DIR="$(dirname "$SCRIPT_PATH")"

    # ── 1. فحص التعديلات المحلية غير المرفوعة ─────────────
    if [ -d "$SCRIPT_DIR/.git" ]; then
        cd "$SCRIPT_DIR" || exit 1

        # فحص جميع الملفات: dev + lib/*
        local CHANGED_FILES=()
        while IFS= read -r -d '' f; do
            CHANGED_FILES+=("$f")
        done < <(git diff --name-only HEAD 2>/dev/null | \
                 grep -E '^(dev|lib/)' | tr '\n' '\0')

        # فحص الملفات الجديدة غير المتتبعة في lib/
        while IFS= read -r -d '' f; do
            CHANGED_FILES+=("$f")
        done < <(git ls-files --others --exclude-standard lib/ dev 2>/dev/null | tr '\n' '\0')

        # فحص الملفات المعلقة في staging
        while IFS= read -r -d '' f; do
            CHANGED_FILES+=("$f")
        done < <(git diff --cached --name-only 2>/dev/null | \
                 grep -E '^(dev|lib/)' | tr '\n' '\0')

        # إزالة التكرار
        local UNIQUE_FILES
        UNIQUE_FILES=$(printf '%s\n' "${CHANGED_FILES[@]}" | sort -u | grep -v '^$')

        if [[ -n "$UNIQUE_FILES" ]]; then
            echo ""
            divider
            log_warn "$(t update_local_changes)"
            echo ""
            echo -e "${BOLD}$(t update_changed_files):${NC}"
            echo "$UNIQUE_FILES" | while read -r file; do
                echo -e "  ${CYAN}●${NC} $file"
            done
            echo ""
            divider

            read -p "$(t update_push_msg_prompt): " PUSH_MSG
            PUSH_MSG="${PUSH_MSG:-update script}"

            # رفع جميع الملفات المتغيرة
            git add dev lib/ 2>/dev/null
            git commit -m "$PUSH_MSG" && git push \
                && log_success "$(t update_pushed)" \
                || { log_error "$(t update_push_failed)"; exit 1; }

            echo ""
        else
            log_info "$(t update_no_changes)"
        fi

        # ── 2. التحقق من التزامن مع GitHub ───────────────────
        echo ""
        log_step "$(t update_syncing)"

        git fetch origin 2>/dev/null

        local LOCAL_HASH REMOTE_HASH
        LOCAL_HASH=$(git rev-parse HEAD 2>/dev/null)
        REMOTE_HASH=$(git rev-parse origin/main 2>/dev/null || git rev-parse origin/master 2>/dev/null)

        if [[ "$LOCAL_HASH" == "$REMOTE_HASH" ]]; then
            log_success "$(t update_in_sync)"
        else
            local BEHIND
            BEHIND=$(git rev-list --count HEAD..origin/main 2>/dev/null || \
                     git rev-list --count HEAD..origin/master 2>/dev/null || echo "?")

            if [[ "$BEHIND" != "0" && "$BEHIND" != "?" ]]; then
                log_warn "$(t update_behind "$BEHIND")"
                read -p "$(t update_pull_prompt) $(t confirm_yn): " PULL_CONFIRM
                if [[ "$PULL_CONFIRM" == "y" ]]; then
                    git pull --rebase origin main 2>/dev/null || \
                    git pull --rebase origin master 2>/dev/null
                    log_success "$(t update_pulled)"
                fi
            fi
        fi

        cd - > /dev/null
    fi

    log_to_file "Update check completed"
    divider
}

function self_rollback() {
    divider
    echo -e "${BOLD}$(t rollback_title)${NC}"
    divider

    local BACKUPS=()
    while IFS= read -r -d '' f; do
        BACKUPS+=("$f")
    done < <(find "$(dirname "$SCRIPT_PATH")" -maxdepth 1 \
             -name "$(basename "$SCRIPT_PATH").backup_v*" -print0 2>/dev/null \
             | sort -rz)

    if [[ ${#BACKUPS[@]} -eq 0 ]]; then
        log_error "$(t rollback_no_backups)"
        return 1
    fi

    echo -e "${BOLD}$(t rollback_available)${NC}"
    for i in "${!BACKUPS[@]}"; do
        local VER
        VER=$(echo "${BACKUPS[$i]}" | grep -o 'v[0-9.]*$')
        echo "  $((i+1))) $VER — ${BACKUPS[$i]}"
    done
    echo ""

    read -p "$(t rollback_choose "${#BACKUPS[@]}"): " CHOICE
    local INDEX=$((CHOICE - 1))

    if [[ -z "${BACKUPS[$INDEX]}" ]]; then
        log_error "$(t rollback_invalid)"
        return 1
    fi

    cp "${BACKUPS[$INDEX]}" "$SCRIPT_PATH"
    chmod +x "$SCRIPT_PATH"
    log_success "$(t rollback_success "$(echo "${BACKUPS[$INDEX]}" | grep -o 'v[0-9.]*$')")"
}
