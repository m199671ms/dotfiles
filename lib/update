#!/bin/bash
# ──────────────────────────────────────
# update.sh — Self Update & Rollback
# ──────────────────────────────────────

function self_update() {
    require_command gh

    eval "$(ssh-agent -s)" > /dev/null
    ssh-add "$HOME_DIR/.ssh/github_personal" > /dev/null 2>&1

    divider
    echo -e "${BOLD}$(t update_checking)${NC}"
    divider

    local SCRIPT_DIR
    SCRIPT_DIR="$(dirname "$SCRIPT_PATH")"

    if [ -d "$SCRIPT_DIR/.git" ]; then
        cd "$SCRIPT_DIR" || exit 1

        if ! git diff --quiet dev 2>/dev/null || \
           git status --short dev 2>/dev/null | grep -q "^[AM]"; then

            log_step "$(t update_local_changes)"
            read -p "$(t update_push_msg_prompt): " PUSH_MSG
            PUSH_MSG="${PUSH_MSG:-update script}"

            git add dev
            git commit -m "$PUSH_MSG" && git push \
                && log_success "$(t update_pushed)" \
                || { log_error "$(t update_push_failed)"; exit 1; }
        else
            log_info "$(t update_no_changes)"
        fi

        cd - > /dev/null
    fi

    local TMP_FILE="$TMP_DIR/_dev_update_tmp"

    if ! gh api repos/m199671ms/dotfiles/contents/dev \
        --jq '.content' | base64 --decode > "$TMP_FILE" 2>/dev/null; then
        log_error "$(t update_download_failed)"
        rm -f "$TMP_FILE"
        exit 1
    fi

    if ! head -1 "$TMP_FILE" | grep -q "bash"; then
        log_error "$(t update_invalid_file)"
        rm -f "$TMP_FILE"
        exit 1
    fi

    local REMOTE_VERSION
    REMOTE_VERSION=$(grep 'SCRIPT_VERSION=' "$TMP_FILE" | head -1 | cut -d'"' -f2)

    if [[ -z "$REMOTE_VERSION" ]]; then
        log_warn "$(t update_no_version)"
        rm -f "$TMP_FILE"
        exit 1
    fi

    echo -e "  $(t update_platform)        : ${CYAN}$OS_TYPE${NC}"
    echo -e "  $(t update_current) : ${YELLOW}$SCRIPT_VERSION${NC}"
    echo -e "  $(t update_latest)  : ${GREEN}$REMOTE_VERSION${NC}"
    echo ""

    if [[ "$SCRIPT_VERSION" == "$REMOTE_VERSION" ]]; then
        log_success "$(t update_uptodate)"
        rm -f "$TMP_FILE"
        return 0
    fi

    read -p "$(t update_confirm "$REMOTE_VERSION") $(t confirm_yn): " CONFIRM
    if [[ "$CONFIRM" != "y" ]]; then
        log_warn "$(t update_cancelled)"
        rm -f "$TMP_FILE"
        return 0
    fi

    local BACKUP_PATH="${SCRIPT_PATH}.backup_v${SCRIPT_VERSION}"
    cp "$SCRIPT_PATH" "$BACKUP_PATH"
    log_info "$(t update_backup "$BACKUP_PATH")"

    mv "$TMP_FILE" "$SCRIPT_PATH"
    chmod +x "$SCRIPT_PATH"

    log_success "$(t update_success "$REMOTE_VERSION")"
    log_to_file "Script updated: $SCRIPT_VERSION → $REMOTE_VERSION"
    echo -e "${CYAN}ℹ️  $(t update_note)${NC}"
}

function self_rollback() {
    divider
    echo -e "${BOLD}$(t rollback_title)${NC}"
    divider

    local BACKUPS=()
    while IFS= read -r -d '' f; do
        BACKUPS+=("$f")
    done < <(find "$(dirname "$SCRIPT_PATH")" -maxdepth 1 \
             -name "$(basename "$SCRIPT_PATH").backup_v*" -print0 2>/dev/null \
             | sort -rz)

    if [[ ${#BACKUPS[@]} -eq 0 ]]; then
        log_error "$(t rollback_no_backups)"
        return 1
    fi

    echo -e "${BOLD}$(t rollback_available)${NC}"
    for i in "${!BACKUPS[@]}"; do
        local VER
        VER=$(echo "${BACKUPS[$i]}" | grep -o 'v[0-9.]*$')
        echo "  $((i+1))) $VER — ${BACKUPS[$i]}"
    done
    echo ""

    read -p "$(t rollback_choose "${#BACKUPS[@]}"): " CHOICE
    local INDEX=$((CHOICE - 1))

    if [[ -z "${BACKUPS[$INDEX]}" ]]; then
        log_error "$(t rollback_invalid)"
        return 1
    fi

    cp "${BACKUPS[$INDEX]}" "$SCRIPT_PATH"
    chmod +x "$SCRIPT_PATH"
    log_success "$(t rollback_success "$(echo "${BACKUPS[$INDEX]}" | grep -o 'v[0-9.]*$')")"
}
