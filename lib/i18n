#!/bin/bash
# ──────────────────────────────────────
# i18n.sh — Internationalization (AR / EN)
# ──────────────────────────────────────

# اللغة الافتراضية / Default language
LANG_PREF="${LANG_PREF:-en}"

# ── دالة الترجمة الرئيسية ──────────────
# الاستخدام: t "مفتاح_الرسالة"
function t() {
    local KEY=$1
    shift
    local MSG=""

    if [[ "$LANG_PREF" == "ar" ]]; then
        MSG="${AR[$KEY]}"
    else
        MSG="${EN[$KEY]}"
    fi

    # fallback إذا المفتاح غير موجود
    [[ -z "$MSG" ]] && MSG="$KEY"

    # استبدال {0} {1} بالمعطيات
    local i=0
    for ARG in "$@"; do
        MSG="${MSG/\{$i\}/$ARG}"
        i=$((i+1))
    done

    echo "$MSG"
}

