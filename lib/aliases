#!/bin/bash
# ──────────────────────────────────────
# aliases.sh — Custom Alias Management
# ──────────────────────────────────────

ALIASES_FILE="$HOME_DIR/.devtoolkit_aliases"

function load_aliases() {
    [ -f "$ALIASES_FILE" ] || return
    source "$ALIASES_FILE"
}

function alias_add() {
    local NAME=$ARG1
    local TARGET=$ARG2

    [[ -z "$NAME" ]]   && read -p "Alias name   : " NAME
    [[ -z "$TARGET" ]] && read -p "Command      : " TARGET
    [[ -z "$NAME" || -z "$TARGET" ]] && log_error "Both name and command are required." && exit 1

    local BUILTIN_CMDS="create-repo push sync status log new-branch switch-branch merge-clean clean-branches undo save-project goto projects remove-project flutter-new flutter-run flutter-build flutter-test flutter-upgrade clean docker-build docker-run docker-list docker-stop docker-clean compose-up compose-down npm-install npm-run npm-build vue-new dotnet-new dotnet-run dotnet-build dotnet-test web-serve ssh-check doctor config info logs update rollback alias-add alias-remove alias-list help"
    if echo "$BUILTIN_CMDS" | grep -qw "$NAME"; then
        log_error "'$NAME' is a built-in command. Choose a different alias name."
        exit 1
    fi

    touch "$ALIASES_FILE"
    grep -v "^alias_map_${NAME}=" "$ALIASES_FILE" > "$TMP_DIR/_alias_tmp" \
        && mv "$TMP_DIR/_alias_tmp" "$ALIASES_FILE"

    echo "alias_map_${NAME}=\"${TARGET}\"" >> "$ALIASES_FILE"
    log_success "Alias added: '${NAME}' → '${TARGET}'"
    echo -e "${CYAN}Usage: dev ${NAME}${NC}"
}

function alias_remove() {
    local NAME=$ARG1
    [[ -z "$NAME" ]] && read -p "Alias to remove: " NAME
    [[ -z "$NAME" ]] && log_error "Alias name is required." && exit 1

    if ! grep -q "^alias_map_${NAME}=" "$ALIASES_FILE" 2>/dev/null; then
        log_error "Alias '$NAME' not found."
        exit 1
    fi

    grep -v "^alias_map_${NAME}=" "$ALIASES_FILE" > "$TMP_DIR/_alias_tmp" \
        && mv "$TMP_DIR/_alias_tmp" "$ALIASES_FILE"
    log_success "Alias '$NAME' removed."
}

function alias_list() {
    divider
    echo -e "${BOLD}⚡ Custom Aliases${NC}"
    divider
    if [ ! -f "$ALIASES_FILE" ] || [ ! -s "$ALIASES_FILE" ]; then
        log_warn "No aliases defined yet."
        echo -e "  Add one with: ${CYAN}dev alias-add <n> <command>${NC}"
        divider
        return
    fi

    while IFS='=' read -r key value; do
        local NAME TARGET
        NAME=$(echo "$key" | sed 's/alias_map_//')
        TARGET=$(echo "$value" | tr -d '"')
        echo -e "  ${GREEN}dev $NAME${NC} → ${CYAN}dev $TARGET${NC}"
    done < "$ALIASES_FILE"
    divider
}

function run_alias() {
    local NAME=$1
    load_aliases

    local VAR_NAME="alias_map_${NAME}"
    local TARGET="${!VAR_NAME}"

    if [[ -z "$TARGET" ]]; then
        log_error "Unknown command: '$NAME'"
        echo -e "  Run ${CYAN}dev help${NC} to see available commands."
        echo -e "  Run ${CYAN}dev alias-list${NC} to see your aliases."
        exit 1
    fi

    log_info "Running alias: dev $NAME → dev $TARGET"

    COMMAND="$TARGET"
    case "$TARGET" in
        create-repo)     create_repo ;;
        push)            quick_push ;;
        sync)            sync_repo ;;
        status)          git_status ;;
        log)             git_log ;;
        new-branch)      new_branch ;;
        switch-branch)   switch_branch ;;
        merge-clean)     merge_and_clean ;;
        clean-branches)  clean_branches ;;
        undo)            undo_commit ;;
        save-project)    save_project ;;
        goto)            goto_project ;;
        projects)        list_projects ;;
        remove-project)  remove_project ;;
        flutter-new)     flutter_new ;;
        flutter-run)     flutter_run_device ;;
        flutter-build)   flutter_build ;;
        flutter-test)    flutter_test ;;
        flutter-upgrade) flutter_upgrade ;;
        clean)           flutter clean && log_success "Cleaned!" ;;
        docker-build)    docker_build ;;
        docker-run)      docker_run ;;
        docker-list)     docker_list ;;
        docker-stop)     docker_stop_all ;;
        docker-clean)    docker_clean ;;
        compose-up)      docker_compose_up ;;
        compose-down)    docker_compose_down ;;
        npm-install)     node_install ;;
        npm-run)         node_run ;;
        npm-build)       node_build ;;
        dotnet-build)    dotnet_build ;;
        dotnet-run)      dotnet_run ;;
        dotnet-test)     dotnet_test ;;
        web-serve)       web_serve ;;
        info)            show_info ;;
        logs)            show_logs ;;
        update)          self_update ;;
        *)               log_error "Cannot alias to unknown command: '$TARGET'" ;;
    esac
}