#!/bin/bash
# ──────────────────────────────────────
# docker.sh — Docker Operations
# ──────────────────────────────────────

function docker_build() {
    require_command docker
    local NAME=$ARG1
    [[ -z "$NAME" ]] && read -p "$(t docker_image_name): " NAME
    [[ -z "$NAME" ]] && log_error "$(t docker_image_required)" && exit 1
    [ ! -f Dockerfile ] && { log_error "$(t docker_no_dockerfile)"; exit 1; }

    read -p "$(t docker_tag): " TAG
    TAG="${TAG:-latest}"

    log_step "$(t docker_building "$NAME:$TAG")"
    run_with_notify "Docker Build $NAME:$TAG" docker build -t "$NAME:$TAG" .
    log_to_file "Docker built: $NAME:$TAG"
}

function docker_run() {
    require_command docker
    local NAME=$ARG1
    [[ -z "$NAME" ]] && read -p "$(t docker_image_name): " NAME
    [[ -z "$NAME" ]] && log_error "$(t docker_image_required)" && exit 1

    read -p "$(t docker_port): " PORT
    read -p "$(t docker_container_name): " CNAME

    local DOCKER_ARGS=(-it --rm)
    [[ -n "$PORT"  ]] && DOCKER_ARGS+=(-p "$PORT")
    [[ -n "$CNAME" ]] && DOCKER_ARGS+=(--name "$CNAME")

    log_step "$(t docker_running "$NAME")"
    docker run "${DOCKER_ARGS[@]}" "$NAME"
}

function docker_list() {
    require_command docker
    divider
    echo -e "${BOLD}$(t docker_images_title)${NC}"
    divider
    docker images
    echo ""
    divider
    echo -e "${BOLD}$(t docker_containers_title)${NC}"
    divider
    docker ps
}

function docker_stop_all() {
    require_command docker
    log_step "$(t docker_stopping)"
    local RUNNING
    RUNNING=$(docker ps -q)
    if [[ -n "$RUNNING" ]]; then
        # shellcheck disable=SC2086
        docker stop $RUNNING && log_success "$(t docker_stopped)"
    else
        log_warn "$(t docker_no_containers)"
    fi
}

function docker_clean() {
    require_command docker
    log_warn "$(t docker_clean_warn)"
    confirm "$(t continue_prompt)" || exit 0
    docker system prune -f && log_success "$(t docker_cleaned)"
}

function docker_compose_up() {
    require_command docker
    [ ! -f docker-compose.yml ] && { log_error "$(t docker_no_compose)"; exit 1; }
    log_step "$(t docker_compose_starting)"
    docker compose up -d && log_success "$(t docker_compose_started)" || log_error "$(t docker_failed)"
}

function docker_compose_down() {
    require_command docker
    log_step "$(t docker_compose_stopping)"
    docker compose down && log_success "$(t docker_compose_stopped)" || log_error "$(t docker_failed)"
}
