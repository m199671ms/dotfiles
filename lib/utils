#!/bin/bash
# ──────────────────────────────────────
# utils.sh — Colors, Logging, Spinner & Helpers
# ──────────────────────────────────────

# --- Colors ---
RED="\033[0;31m"
GREEN="\033[0;32m"
YELLOW="\033[1;33m"
CYAN="\033[0;36m"
BLUE="\033[0;34m"
MAGENTA="\033[0;35m"
BOLD="\033[1m"
NC="\033[0m"

# --- Logging ---
function log_info()    { echo -e "${CYAN}ℹ️  $1${NC}"; }
function log_success() { echo -e "${GREEN}✅ $1${NC}"; }
function log_warn()    { echo -e "${YELLOW}⚠️  $1${NC}"; }
function log_error()   { echo -e "${RED}❌ $1${NC}"; }
function log_step()    { echo -e "${BLUE}▶  $1${NC}"; }
function divider()     { echo -e "${CYAN}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"; }

# ──────────────────────────────────────
# LOG ROTATION — keep last 1000 lines
# ──────────────────────────────────────
function log_to_file() {
    echo "[$(date '+%Y-%m-%d %H:%M:%S')] [$OS_TYPE] $1" >> "$LOG_FILE"

    local LINE_COUNT
    LINE_COUNT=$(wc -l < "$LOG_FILE" 2>/dev/null || echo 0)
    if (( LINE_COUNT > 1000 )); then
        local TMP_LOG="$TMP_DIR/_devtoolkit_log_tmp"
        tail -800 "$LOG_FILE" > "$TMP_LOG" && mv "$TMP_LOG" "$LOG_FILE"
        echo "[$(date '+%Y-%m-%d %H:%M:%S')] [system] $(t log_rotated)" >> "$LOG_FILE"
    fi
}

# --- Guards ---
function require_command() {
    local CMD=$1
    if ! command -v "$CMD" &>/dev/null; then
        log_error "$(t not_installed "$CMD")"
        case "$CMD" in
            git)      log_info "$(t install_git)" ;;
            gh)       log_info "$(t install_gh)" ;;
            flutter)  log_info "$(t install_flutter)" ;;
            docker)   log_info "$(t install_docker)" ;;
            npm|node) log_info "$(t install_node)" ;;
            dotnet)   log_info "$(t install_dotnet)" ;;
            *)        log_info "$(t install_generic "$CMD")" ;;
        esac
        exit 1
    fi
}

function require_git_repo() {
    if [ ! -d ".git" ]; then
        log_error "$(t git_not_repo)"
        log_info "$(t git_not_repo_tip1)"
        log_info "$(t git_not_repo_tip2)"
        exit 1
    fi
}

# --- Input ---
function confirm() {
    read -p "$1 (y/n): " _CONFIRM
    [[ "$_CONFIRM" == "y" ]]
}

# --- Editor & Browser ---
function open_editor() {
    local DIR=${1:-.}
    load_config
    case "$OS_TYPE" in
        windows)
            if command -v "$EDITOR_PREF" &>/dev/null; then
                "$EDITOR_PREF" "$DIR" &
            elif command -v code &>/dev/null; then
                code "$DIR" &
            fi
            ;;
        *)
            command -v "$EDITOR_PREF" &>/dev/null && "$EDITOR_PREF" "$DIR" &
            ;;
    esac
}

function open_browser() {
    local URL=$1
    case "$OS_TYPE" in
        macos)   open "$URL" ;;
        linux)   xdg-open "$URL" 2>/dev/null ;;
        windows) cmd.exe /c start "$URL" 2>/dev/null ;;
    esac
}

# ──────────────────────────────────────
# SPINNER
# ──────────────────────────────────────

_SPINNER_PID=""

function spinner_start() {
    local LABEL="${1:-...}"
    [[ ! -t 1 ]] && return

    local FRAMES=("⠋" "⠙" "⠹" "⠸" "⠼" "⠴" "⠦" "⠧" "⠇" "⠏")
    (
        local i=0
        while true; do
            printf "\r${CYAN}%s${NC} %s  " "${FRAMES[$i]}" "$LABEL"
            i=$(( (i + 1) % ${#FRAMES[@]} ))
            sleep 0.1
        done
    ) &
    _SPINNER_PID=$!
    disown "$_SPINNER_PID" 2>/dev/null
}

function spinner_stop() {
    if [[ -n "$_SPINNER_PID" ]]; then
        kill "$_SPINNER_PID" 2>/dev/null
        wait "$_SPINNER_PID" 2>/dev/null
        _SPINNER_PID=""
        printf "\r\033[K"
    fi
}

# ──────────────────────────────────────
# NOTIFICATIONS
# ──────────────────────────────────────

function notify() {
    local TITLE=$1 MESSAGE=$2 SUCCESS=$3

    case "$OS_TYPE" in
        macos)
            local SOUND="Glass"
            [[ "$SUCCESS" == "false" ]] && SOUND="Basso"
            osascript -e "display notification \"$MESSAGE\" with title \"$TITLE\" sound name \"$SOUND\"" 2>/dev/null
            ;;
        windows)
            powershell.exe -Command "
                Add-Type -AssemblyName System.Windows.Forms
                \$notify = New-Object System.Windows.Forms.NotifyIcon
                \$notify.Icon = [System.Drawing.SystemIcons]::Information
                \$notify.Visible = \$true
                \$notify.ShowBalloonTip(5000, '$TITLE', '$MESSAGE', [System.Windows.Forms.ToolTipIcon]::Info)
            " 2>/dev/null
            ;;
        linux)
            command -v notify-send &>/dev/null && notify-send "$TITLE" "$MESSAGE" 2>/dev/null
            ;;
    esac

    if [[ "$SUCCESS" == "false" ]]; then
        log_error "$TITLE — $MESSAGE"
    else
        log_success "$TITLE — $MESSAGE"
    fi
}

# ──────────────────────────────────────
# run_with_notify + spinner
# Usage: run_with_notify "Title" command arg1 arg2 ...
# ──────────────────────────────────────
function run_with_notify() {
    local TITLE=$1
    shift

    local START
    START=$(date +%s)

    spinner_start "$TITLE"
    "$@"
    local EXIT_CODE=$?
    spinner_stop

    local END DURATION TIME_STR
    END=$(date +%s)
    DURATION=$((END - START))

    if   (( DURATION >= 3600 )); then
        TIME_STR="$((DURATION/3600))h $((DURATION%3600/60))m"
    elif (( DURATION >= 60 )); then
        TIME_STR="$((DURATION/60))m $((DURATION%60))s"
    else
        TIME_STR="${DURATION}s"
    fi

    if [ $EXIT_CODE -eq 0 ]; then
        notify "✅ $TITLE" "$(t notify_completed "$TIME_STR")" "true"
        log_to_file "$TITLE completed in $TIME_STR"
    else
        notify "❌ $TITLE" "$(t notify_failed "$TIME_STR")" "false"
        log_to_file "$TITLE FAILED after $TIME_STR"
        _suggest_fix "$TITLE" "$EXIT_CODE"
    fi

    return $EXIT_CODE
}

# ──────────────────────────────────────
# Smart error suggestions
# ──────────────────────────────────────
function _suggest_fix() {
    local CONTEXT=$1

    echo ""
    echo -e "${YELLOW}$(t suggest_fix_title)${NC}"

    case "$CONTEXT" in
        *Flutter*Build*APK*|*Flutter*Build*Android*)
            echo -e "  • $(t suggest_flutter_apk1)"
            echo -e "  • $(t suggest_flutter_apk2) ${CYAN}dev clean${NC}"
            echo -e "  • $(t suggest_flutter_apk3) ${CYAN}flutter pub get${NC}"
            ;;
        *Flutter*Build*iOS*)
            echo -e "  • $(t suggest_flutter_ios1)"
            echo -e "  • $(t suggest_flutter_ios2) ${CYAN}cd ios && pod install --repo-update${NC}"
            ;;
        *Flutter*Build*Web*)
            echo -e "  • $(t suggest_flutter_web) ${CYAN}flutter channel stable && flutter upgrade${NC}"
            ;;
        *Flutter*Tests*)
            echo -e "  • $(t suggest_flutter_test) ${CYAN}flutter test --verbose${NC}"
            ;;
        *Docker*Build*)
            echo -e "  • $(t suggest_docker1) ${CYAN}dev doctor${NC}"
            echo -e "  • $(t suggest_docker2)"
            echo -e "  • $(t suggest_docker3) ${CYAN}docker system prune -f${NC}"
            ;;
        *Node*Build*|*npm*)
            echo -e "  • $(t suggest_npm1) ${CYAN}dev npm-install${NC}"
            echo -e "  • $(t suggest_npm2)"
            ;;
        *.NET*Build*)
            echo -e "  • $(t suggest_dotnet_build) ${CYAN}dotnet restore${NC}"
            echo -e "  • $(t suggest_dotnet_version) ${CYAN}dotnet --version${NC}"
            ;;
        *.NET*Tests*)
            echo -e "  • $(t suggest_dotnet_test) ${CYAN}dotnet test --verbosity detailed${NC}"
            ;;
        *)
            echo -e "  • $(t suggest_generic1) ${CYAN}dev logs${NC}"
            echo -e "  • $(t suggest_generic2) ${CYAN}dev doctor${NC}"
            ;;
    esac
    echo ""
}
